# =============================================================================
# SIRINE bot — environment template.
# Copy to .env (cp .env.example .env), fill the CLIENT section, run `make setup`.
# `make setup` auto-generates everything in the GENERATED section that is still
# empty, and fills the WIRED section itself during provisioning.
# NEVER commit .env.
# =============================================================================

# --- CLIENT: you must provide these (3 values + admin login) -----------------
# LLM backend — pick ONE:
#   aistudio (default): set GEMINI_API_KEY below. Simplest. Free tier stops at ~20/day → use a billed key.
#   vertex            : set LLM_PROVIDER=vertex + the GOOGLE_CLOUD_* block (powers the agent via Vertex
#                       AI; works with the $300 GCP trial; no daily free cliff). See RUNBOOK "Using Vertex".
GEMINI_API_KEY=                     # aistudio only — aistudio.google.com/apikey
FB_APP_ID=                          # Meta app ID (developers.facebook.com → your app → Settings → Basic)
FB_APP_SECRET=                      # Meta app secret (same page)
FRONTEND_URL=http://localhost:3037  # PUBLIC https URL of Chatwoot (your domain or tunnel), e.g. https://chat.example.com

# --- VERTEX AI (only if LLM_PROVIDER=vertex) ---------------------------------
LLM_PROVIDER=aistudio               # aistudio | vertex
GOOGLE_CLOUD_PROJECT=               # your GCP project id (vertex)
GOOGLE_CLOUD_LOCATION=us-central1   # a region where Gemini is available (vertex)
# Auth — pick ONE:
#   On a GCP VM with the service account ATTACHED: leave GOOGLE_APPLICATION_CREDENTIALS empty
#     (below). ADC uses the VM identity automatically — no key file. (Recommended.)
#   On a non-GCP host: set GOOGLE_APPLICATION_CREDENTIALS=/app/vertex/sa.json and drop the
#     downloaded key JSON at ./agent-handler/vertex/sa.json (git-ignored, mounted read-only).
GOOGLE_APPLICATION_CREDENTIALS=     # empty on a GCP VM with attached SA; else /app/vertex/sa.json

DIRECTUS_ADMIN_EMAIL=owner@example.com  # login for the catalog admin UI (:8055)
DIRECTUS_ADMIN_PASSWORD=                # pick a strong password (auto-generated if left empty)
CHATWOOT_ADMIN_EMAIL=owner@example.com  # login for the Chatwoot inbox UI
CHATWOOT_ADMIN_PASSWORD=                # auto-generated if left empty (must contain upper/lower/digit/special)

# --- GENERATED: leave empty — `make setup` fills any blank with a strong secret
POSTGRES_PASSWORD=
REDIS_PASSWORD=
CATALOG_RO_PASSWORD=                # read-only DB role used by retrieval-api
DIRECTUS_KEY=                       # Directus instance key
DIRECTUS_SECRET=                    # Directus instance secret
DIRECTUS_TOKEN=                     # static admin token (bot reads images/merchants, writes orders)
CHATWOOT_SECRET_KEY_BASE=           # Rails secret (64 hex)
RETRIEVAL_API_KEY=                  # internal x-api-key between agent-handler and retrieval-api
FB_VERIFY_TOKEN=                    # any random string; you paste the SAME value in the Meta webhook config

# --- WIRED: filled automatically by `make setup` (Chatwoot provisioning) ------
CHATWOOT_API_ACCESS_TOKEN=          # admin API token (created by bootstrap)
CHATWOOT_INBOX_ID=
CHATWOOT_INBOX_IDENTIFIER=
CHATWOOT_AGENT_BOT_ID=
CHATWOOT_AGENT_BOT_TOKEN=

# --- DEFAULTS: fine as-is for most installs ----------------------------------
TZ=Africa/Algiers
POSTGRES_USER=app
CATALOG_RO_ROLE=catalog_ro
GEMINI_MODEL=gemini-2.5-flash       # swap model id here without touching code
CHATWOOT_ACCOUNT_ID=1
DIRECTUS_PUBLIC_URL=http://localhost:8055  # set to your public Directus URL if you expose it
AGENT_MAX_STEPS=4                   # max tool-calling iterations per customer turn
AGENT_HISTORY_TURNS=16              # conversation memory depth (text turns)
AGENT_MAX_IMAGES=3                  # max product photos per reply
AGENT_DEBOUNCE_MS=4000              # wait this long for the customer to stop typing, then answer all their messages as ONE turn

# --- EDGE PROXY / TLS (only when you have a domain) --------------------------
# Two subdomains, both A-record → the VM's IP. Caddy auto-issues TLS for each.
# Then: FRONTEND_URL=https://${CHAT_HOST}, DIRECTUS_PUBLIC_URL=https://${ADMIN_HOST}, and bring up
# with: docker compose --profile edge up -d
CHAT_HOST=                          # e.g. chat.example.com  → Chatwoot + Meta webhook
ADMIN_HOST=                         # e.g. admin.example.com → Directus admin UI
