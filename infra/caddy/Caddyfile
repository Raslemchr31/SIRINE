# Edge proxy for the SIRINE stack. CHAT_HOST / ADMIN_HOST come from .env (derived from the domain).
# Caddy fetches and renews TLS certificates automatically (Let's Encrypt) for both hostnames.

# chat.<domain> → Chatwoot (inbox UI + Facebook page connect), with the Meta webhook relay
# routed to agent-handler so ad-attribution referrals are captured before forwarding to Chatwoot.
{$CHAT_HOST} {
	handle /meta/webhook* {
		reverse_proxy agent-handler:8082
	}
	handle {
		reverse_proxy chatwoot-rails:3000
	}
}

# admin.<domain> → Directus (catalog + orders admin UI for the team).
{$ADMIN_HOST} {
	reverse_proxy directus:8055
}
