# Edge proxy for the SIRINE stack. DOMAIN comes from .env (derived from FRONTEND_URL
# by setup/bootstrap.sh). Caddy fetches/renews the TLS certificate automatically.
{$DOMAIN} {
	# Meta webhook → agent-handler relay (ad attribution), which forwards to Chatwoot.
	handle /meta/webhook* {
		reverse_proxy agent-handler:8082
	}
	# Everything else (Chatwoot UI, Facebook page connect, agent dashboard, /bot fallback).
	handle {
		reverse_proxy chatwoot-rails:3000
	}
}
